{
  // Client config for the ROBOT PC scripts (robot_agent.py, arm_agent.py --
  // camera_pub.py does NOT use Zenoh, see its module docstring). The
  // `connect.endpoints` value below is NEVER actually
  // used: robot/zenoh_config.py's load_robot_config() always overwrites it
  // from the required OPERATOR_IP environment variable before opening the
  // session (see that module for why -- a stale hardcoded IP here used to
  // cause robot_agent.py to silently connect nowhere after the operator
  // Mac's DHCP lease changed). This file only still needs to parse as valid
  // Zenoh config JSON5; the endpoint below is illustrative, not load-bearing.
  //
  //     OPERATOR_IP=192.168.15.111 python robot_agent.py
  //
  // Find the operator PC's current IP with `ipconfig getifaddr en0` on the
  // Mac (local LAN, lower latency) or `tailscale ip -4` (Tailscale, 100.x
  // range, when robot and operator aren't on the same network).
  mode: "client",
  connect: {
    endpoints: ["tcp/192.168.15.111:7447"],
  },
}
